# ============================================================
# OfferPilot 开发环境变量
# 复制此文件为 .env.production 并修改密码用于生产环境
# ============================================================

# MySQL
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=offerpilot

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# DashScope API Key（需替换为真实 Key）
DASHSCOPE_API_KEY=sk-xxx

# Embedding API Key（可选，默认回退使用 DASHSCOPE_API_KEY）
# 当 LLM 切换为 DeepSeek 等不支持 Embedding 的 Provider 时，
# 请将此变量设为 DashScope 或 OpenAI 的 Key 以保证向量检索正常
EMBEDDING_API_KEY=

# JWT 签名密钥（需替换为随机字符串）
JWT_SECRET=dev-jwt-secret-change-in-production
